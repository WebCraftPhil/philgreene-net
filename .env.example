# Required for the audit request form
MAILTRAP_API_TOKEN=your_mailtrap_api_token
MAILTRAP_FROM_EMAIL=me@philgreene.net
MAILTRAP_FROM_NAME=Phil Greene

# Optional. Used only by npm run mailtrap:test-send.
MAILTRAP_TEST_RECIPIENT=vtguy65@gmail.com

# Required in production for the free website checkup
# Create one managed Turnstile widget for philgreene.net and www.philgreene.net.
VITE_TURNSTILE_SITE_KEY=your_public_turnstile_site_key
TURNSTILE_SECRET_KEY=your_private_turnstile_secret_key

# Required. Use a random value of at least 32 characters to encrypt short-lived report tokens.
SCAN_REPORT_SECRET=replace_with_a_long_random_secret

# Optional. When set, the site loads Plausible and sends the documented conversion events.
VITE_PLAUSIBLE_DOMAIN=philgreene.net
